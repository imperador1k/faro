# 🚀 FARO — ENVIRONMENT VARIABLES
# Copy this file to .env or .env.local and fill in the values.
#
# For local development with Docker (recommended):
#   docker compose up -d           # starts PostgreSQL + Redis
#   DATABASE_URL is auto-configured via Docker network
#   Redis is available at http://localhost:6379

# 🌍 GENERAL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 🗄️ DATABASE (PostgreSQL)
# Docker: postgresql://postgres:password@localhost:5432/faro
# Supabase: postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/faro"

# 🔑 AUTH (Clerk) — https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/learn
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/learn
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/auth-success
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/auth-success

# ⚡ SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# 🧠 AI (Google Gemini) — https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy...
GEMINI_API_KEY_1=AIzaSy...
GEMINI_API_KEY_2=AIzaSy...
GEMINI_API_KEY_3=AIzaSy...

# 💳 PAYMENTS (Stripe)
NEXT_PUBLIC_STRIPE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...

# 🛡️ ADMIN & SECURITY
ADMIN_ALLOWED_USER_IDS="user_2... user_3..."
ADMIN_SUDO_HASH="..."
CRON_SECRET=my-cron-secret-123

# 🔗 INTEGRATIONS
NEXT_PUBLIC_GIPHY_API_KEY=...
GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# 🔔 NOTIFICATIONS (OneSignal)
ONESIGNAL_APP_ID=...
ONESIGNAL_REST_API_KEY=...

# 🚥 RATE LIMITING (Upstash Redis)
# Docker: http://localhost:6379 (no token needed)
# Production: https://[...].upstash.io
UPSTASH_REDIS_REST_URL=http://localhost:6379
UPSTASH_REDIS_REST_TOKEN=

# 🐛 SENTRY
SENTRY_AUTH_TOKEN=sntrys_...

# 📧 EMAILS (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Faro <noreply@miguelweb.dev>"
SUPPORT_EMAIL=youremail@gmail.com

# 🪝 CLERK WEBHOOK (Email localization)
# Cria em: https://dashboard.clerk.com → Webhooks → Add Endpoint
# URL: https://teudominio.vercel.app/api/webhooks/clerk
# Evento: email.created
CLERK_WEBHOOK_SECRET=whsec_...
