{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default-capability",
  "description": "Permissões core para o wrapper remoto",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    "deep-link:default",
    "updater:default",
    "process:allow-restart"
  ],
  "remote": {
    "urls": ["http://localhost:3000/**", "https://myduolingo.vercel.app/**"]
  }
}
